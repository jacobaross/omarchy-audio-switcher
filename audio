#!/usr/bin/env bash

set -u

readonly CONFIG_FILE="${AUDIO_SWITCHER_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/audio-switcher/config}"

if [[ -r "$CONFIG_FILE" ]]; then
  # This is a user-owned shell configuration file.
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi

# Environment variables take precedence over the configuration file. These
# defaults match the setup this utility was originally built for.
HEADSET_SINK="${AUDIO_HEADSET_SINK:-${HEADSET_SINK:-alsa_output.usb-SteelSeries_Arctis_7P_-00.analog-stereo}}"
SPEAKERS_SINK="${AUDIO_SPEAKERS_SINK:-${SPEAKERS_SINK:-alsa_output.pci-0000_c1_00.1.hdmi-stereo-extra3}}"
HEADSET_SOURCE="${AUDIO_HEADSET_SOURCE:-${HEADSET_SOURCE:-alsa_input.usb-SteelSeries_Arctis_7P_-00.mono-fallback}}"
SPEAKERS_SOURCE="${AUDIO_SPEAKERS_SOURCE:-${SPEAKERS_SOURCE:-alsa_input.usb-046d_HD_Pro_Webcam_C920_724A625F-02.analog-stereo}}"
readonly HEADSET_SINK SPEAKERS_SINK HEADSET_SOURCE SPEAKERS_SOURCE

usage() {
  cat <<'EOF'
Usage: audio {headset|speakers|toggle|status}

Switch the default PipeWire audio sink and source by their stable node names.

Commands:
  headset   Switch output and microphone to the configured headset
  speakers  Switch output and microphone to the configured speakers
  toggle    Switch both output and microphone between the two setups
  status    Print Headset, Speakers, or Unknown
EOF
}

notify() {
  command -v notify-send >/dev/null 2>&1 || return 0
  notify-send -a audio "$@" >/dev/null 2>&1 || true
}

current_node_name() {
  local identifier=$1 inspect_output node_name

  inspect_output=$(wpctl inspect "$identifier" 2>/dev/null) || return 1
  node_name=$(awk '
    index($0, "node.name = \"") {
      sub(/^.*node\.name = "/, "")
      sub(/"$/, "")
      print
      exit
    }
  ' <<<"$inspect_output")

  [[ -n "$node_name" ]] || return 1
  printf '%s\n' "$node_name"
}

current_sink_name() {
  current_node_name '@DEFAULT_AUDIO_SINK@'
}

current_source_name() {
  current_node_name '@DEFAULT_AUDIO_SOURCE@'
}

node_id_from_status() {
  local status_output=$1 target=$2 section=$3

  awk -v target="$target" -v section="$section" '
    index($0, section ":") {
      in_section = 1
      next
    }
    in_section && /(Devices|Sinks|Sources|Filters|Streams):/ {
      in_section = 0
    }
    in_section {
      line = $0
      sub(/^[^0-9]*/, "", line)
      if (line !~ /^[0-9]+\./) {
        next
      }

      id = line
      sub(/\..*$/, "", id)
      sub(/^[0-9]+\.[[:space:]]*/, "", line)
      name = line
      sub(/[[:space:]].*$/, "", name)

      if (name == target) {
        print id
        exit
      }
    }
  ' <<<"$status_output"
}

switch_to() {
  local target_sink=$1 target_source=$2 label=$3 icon=$4
  local status_output sink_id source_id previous_source_name previous_source_id

  if ! status_output=$(wpctl status --name 2>/dev/null); then
    printf 'audio: unable to query PipeWire; is it running?\n' >&2
    notify -u critical 'Audio switch failed' 'Unable to query PipeWire'
    return 1
  fi

  sink_id=$(node_id_from_status "$status_output" "$target_sink" 'Sinks')
  if [[ -z "$sink_id" ]]; then
    printf 'audio: %s output is unavailable (%s)\n' "$label" "$target_sink" >&2
    notify -u critical 'Audio switch failed' "$label output is unavailable"
    return 1
  fi

  source_id=$(node_id_from_status "$status_output" "$target_source" 'Sources')
  if [[ -z "$source_id" ]]; then
    printf 'audio: %s microphone is unavailable (%s)\n' "$label" "$target_source" >&2
    notify -u critical 'Audio switch failed' "$label microphone is unavailable"
    return 1
  fi

  previous_source_name=$(current_source_name) || previous_source_name=''
  previous_source_id=$(node_id_from_status "$status_output" "$previous_source_name" 'Sources')

  # wpctl requires a runtime object ID here. Resolve it from the exact node
  # name above every time, so changing PipeWire IDs are never stored or relied on.
  if ! wpctl set-default "$source_id"; then
    printf 'audio: failed to switch to the %s microphone\n' "$label" >&2
    notify -u critical 'Audio switch failed' "Could not switch to the $label microphone"
    return 1
  fi

  if ! wpctl set-default "$sink_id"; then
    if [[ -n "$previous_source_id" ]]; then
      wpctl set-default "$previous_source_id" >/dev/null 2>&1 || true
    fi
    printf 'audio: failed to switch to the %s output\n' "$label" >&2
    notify -u critical 'Audio switch failed' "Could not switch to the $label output"
    return 1
  fi

  notify "$icon $label"
}

print_status() {
  local sink_name source_name

  sink_name=$(current_sink_name) || sink_name=''
  source_name=$(current_source_name) || source_name=''
  case "$sink_name:$source_name" in
    "$HEADSET_SINK:$HEADSET_SOURCE") printf 'Headset\n' ;;
    "$SPEAKERS_SINK:$SPEAKERS_SOURCE") printf 'Speakers\n' ;;
    *) printf 'Unknown\n' ;;
  esac
}

main() {
  if [[ $# -ne 1 ]]; then
    usage >&2
    return 64
  fi

  if ! command -v wpctl >/dev/null 2>&1; then
    printf 'audio: wpctl is required but was not found in PATH\n' >&2
    return 127
  fi

  case $1 in
    headset)
      switch_to "$HEADSET_SINK" "$HEADSET_SOURCE" 'Headset' '🎧'
      ;;
    speakers)
      switch_to "$SPEAKERS_SINK" "$SPEAKERS_SOURCE" 'Speakers' '🔊'
      ;;
    toggle)
      local sink_name
      if ! sink_name=$(current_sink_name); then
        printf 'audio: unable to determine the current default sink\n' >&2
        return 1
      fi

      case "$sink_name" in
        "$HEADSET_SINK") switch_to "$SPEAKERS_SINK" "$SPEAKERS_SOURCE" 'Speakers' '🔊' ;;
        "$SPEAKERS_SINK") switch_to "$HEADSET_SINK" "$HEADSET_SOURCE" 'Headset' '🎧' ;;
        *)
          printf 'audio: current default sink is neither headset nor speakers (%s)\n' "$sink_name" >&2
          return 1
          ;;
      esac
      ;;
    status)
      print_status
      ;;
    *)
      printf 'audio: invalid command: %s\n\n' "$1" >&2
      usage >&2
      return 64
      ;;
  esac
}

main "$@"
