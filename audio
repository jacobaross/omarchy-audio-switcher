#!/usr/bin/env bash

set -u

readonly CONFIG_FILE="${AUDIO_SWITCHER_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/audio-switcher/config}"

if [[ -r "$CONFIG_FILE" ]]; then
  # This is a user-owned shell configuration file.
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi

# Environment variables take precedence over the configuration file. These
# defaults match the setup this utility was originally built for.
HEADSET_SINK="${AUDIO_HEADSET_SINK:-${HEADSET_SINK:-alsa_output.usb-SteelSeries_Arctis_7P_-00.analog-stereo}}"
SPEAKERS_SINK="${AUDIO_SPEAKERS_SINK:-${SPEAKERS_SINK:-alsa_output.pci-0000_c1_00.1.hdmi-stereo-extra3}}"
readonly HEADSET_SINK SPEAKERS_SINK

usage() {
  cat <<'EOF'
Usage: audio {headset|speakers|toggle|status}

Switch the default PipeWire audio sink by its stable node name.

Commands:
  headset   Switch to the configured headset
  speakers  Switch to the configured speakers
  toggle    Switch between the headset and speakers
  status    Print Headset, Speakers, or Unknown
EOF
}

notify() {
  command -v notify-send >/dev/null 2>&1 || return 0
  notify-send -a audio "$@" >/dev/null 2>&1 || true
}

current_sink_name() {
  local inspect_output sink_name

  inspect_output=$(wpctl inspect '@DEFAULT_AUDIO_SINK@' 2>/dev/null) || return 1
  sink_name=$(awk '
    index($0, "node.name = \"") {
      sub(/^.*node\.name = "/, "")
      sub(/"$/, "")
      print
      exit
    }
  ' <<<"$inspect_output")

  [[ -n "$sink_name" ]] || return 1
  printf '%s\n' "$sink_name"
}

find_sink_id() {
  local target=$1 status_output sink_id

  status_output=$(wpctl status --name 2>/dev/null) || return 2
  sink_id=$(awk -v target="$target" '
    /Sinks:/ {
      in_sinks = 1
      next
    }
    in_sinks && /(Sources|Filters|Streams):/ {
      in_sinks = 0
    }
    in_sinks {
      line = $0
      sub(/^[^0-9]*/, "", line)
      if (line !~ /^[0-9]+\./) {
        next
      }

      id = line
      sub(/\..*$/, "", id)
      sub(/^[0-9]+\.[[:space:]]*/, "", line)
      name = line
      sub(/[[:space:]].*$/, "", name)

      if (name == target) {
        print id
        exit
      }
    }
  ' <<<"$status_output")

  [[ -n "$sink_id" ]] || return 3
  printf '%s\n' "$sink_id"
}

switch_to() {
  local target=$1 label=$2 icon=$3 sink_id rc

  sink_id=$(find_sink_id "$target")
  rc=$?
  case $rc in
    0) ;;
    2)
      printf 'audio: unable to query PipeWire; is it running?\n' >&2
      notify -u critical 'Audio switch failed' 'Unable to query PipeWire'
      return 1
      ;;
    3)
      printf 'audio: %s is unavailable (%s)\n' "$label" "$target" >&2
      notify -u critical 'Audio switch failed' "$label is unavailable"
      return 1
      ;;
    *)
      printf 'audio: failed to resolve %s\n' "$label" >&2
      return 1
      ;;
  esac

  # wpctl requires a runtime object ID here. Resolve it from the exact node
  # name above every time, so changing PipeWire IDs are never stored or relied on.
  if ! wpctl set-default "$sink_id"; then
    printf 'audio: failed to switch to %s\n' "$label" >&2
    notify -u critical 'Audio switch failed' "Could not switch to $label"
    return 1
  fi

  notify "$icon $label"
}

print_status() {
  local sink_name

  sink_name=$(current_sink_name) || sink_name=''
  case "$sink_name" in
    "$HEADSET_SINK") printf 'Headset\n' ;;
    "$SPEAKERS_SINK") printf 'Speakers\n' ;;
    *) printf 'Unknown\n' ;;
  esac
}

main() {
  if [[ $# -ne 1 ]]; then
    usage >&2
    return 64
  fi

  if ! command -v wpctl >/dev/null 2>&1; then
    printf 'audio: wpctl is required but was not found in PATH\n' >&2
    return 127
  fi

  case $1 in
    headset)
      switch_to "$HEADSET_SINK" 'Headset' '🎧'
      ;;
    speakers)
      switch_to "$SPEAKERS_SINK" 'Speakers' '🔊'
      ;;
    toggle)
      local sink_name
      if ! sink_name=$(current_sink_name); then
        printf 'audio: unable to determine the current default sink\n' >&2
        return 1
      fi

      case "$sink_name" in
        "$HEADSET_SINK") switch_to "$SPEAKERS_SINK" 'Speakers' '🔊' ;;
        "$SPEAKERS_SINK") switch_to "$HEADSET_SINK" 'Headset' '🎧' ;;
        *)
          printf 'audio: current default sink is neither headset nor speakers (%s)\n' "$sink_name" >&2
          return 1
          ;;
      esac
      ;;
    status)
      print_status
      ;;
    *)
      printf 'audio: invalid command: %s\n\n' "$1" >&2
      usage >&2
      return 64
      ;;
  esac
}

main "$@"
